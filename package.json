{
  "name": "codex-notebook-local",
  "version": "0.1.0",
  "description": "Local web UI wrapper for the Codex CLI.",
  "type": "module",
  "bin": {
    "codex-notebook": "dist/bin/codex-notebook.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client \"tsx watch src/server/index.ts --dev\" \"vite --host 127.0.0.1 --port 5173\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "start": "node dist/bin/codex-notebook.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.8.1",
    "express": "^4.18.3",
    "lucide-react": "^1.14.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
